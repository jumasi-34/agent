{
  "routing_table": {
    "version": "1.0.0",
    "updated": "2026-07-20",
    "routing_rules": [
      {
        "id": "RULE_01_PRODUCT_FIRST",
        "title": "Product Agent 최우선 가동",
        "description": "사용자 및 비즈니스 의도가 수집되면 항상 Product Agent를 실행하여 PRD와 아키텍처 연계 기반을 다집니다."
      },
      {
        "id": "RULE_02_ARCHITECTURE_BEFORE_CODE",
        "title": "설계 우선 원칙",
        "description": "구조적 변경이 발생하는 모든 작업은 구현 에이전트 진입 전 반드시 Architecture Agent를 통해 물리/논리 설계 무결성을 승인받아야 합니다."
      },
      {
        "id": "RULE_03_DESIGN_SYSTEM_COMPLIANCE",
        "title": "디자인 가이드라인 준수",
        "description": "모든 UI 개발은 Design Agent를 거쳐 미학적 일관성(컬러, 폰트, Material 아이콘 사용률) 및 컴포넌트 재사용성을 보장받아야 합니다."
      },
      {
        "id": "RULE_04_QUALITY_ALWAYS",
        "title": "퀄리티 게이트 상시 피드백",
        "description": "모든 코드 변경 및 패키지 작업은 배포 전 반드시 Quality Agent를 경유해 정적 리뷰 피드백 및 단위 검증을 통과해야 합니다."
      },
      {
        "id": "RULE_05_DOCUMENTATION_REQUIRED",
        "title": "설계 변경 문서 자산화",
        "description": "아키텍처, 쿼리, UI 등의 신설/개선이 마감되면 Documentation Agent를 통해 관련 기술 사양을 영속 마크다운으로 보존합니다."
      },
      {
        "id": "RULE_06_LAZY_LOADING_BINDING",
        "title": "최소 지연 바인딩 (Lazy Loading)",
        "description": "Router는 모든 에이전트를 가동하지 않고, 사용자의 범위에 최적화된 '최소 정예 에이전트 파이프라인'만 구동합니다."
      }
    ],
